{% assign team_members = site.data.team | sort: "order" %}
<script id="lab-graph-data" type="application/json">
{
  "people": [
    {% for member in team_members %}
      {
        "id": {{ member.slug | jsonify }},
        "name": {{ member.name | jsonify }},
        "role": {{ member.role | jsonify }},
        "roleLabel": {{ member.role_label | jsonify }},
        "groupLabel": {{ member.role_group_label | jsonify }},
        "title": {{ member.title | jsonify }},
        "photo": {{ member.photo | jsonify }},
        "profilePath": {{ member.profile_path | jsonify }},
        "email": {{ member.email | jsonify }},
        "externalUrl": {{ member.external_url | jsonify }},
        "scholarUrl": {{ member.scholar_url | jsonify }},
        "orcidUrl": {{ member.orcid_url | jsonify }},
        "githubUrl": {{ member.github_url | jsonify }},
        "linkedinUrl": {{ member.linkedin_url | jsonify }},
        "interests": {{ member.interests | jsonify }},
        "publicationCount": {{ member.selected_publications | size | jsonify }},
        "publications": [
          {% for publication in member.selected_publications %}
            {
              "id": {{ publication.title | slugify | append: '-' | append: publication.year | jsonify }},
              "title": {{ publication.title | jsonify }},
              "year": {{ publication.year | jsonify }},
              "venue": {{ publication.venue | jsonify }},
              "doiUrl": {{ publication.doi_url | jsonify }},
              "url": {{ publication.url | jsonify }},
              "pdf": {{ publication.pdf | jsonify }},
              "code": {{ publication.code | jsonify }},
              "website": {{ publication.website | jsonify }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
