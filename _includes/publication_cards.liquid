<div class="member-profile-publications publications">
  <ol class="bibliography">
    {% for publication in include.publications %}
      {% assign keyword_items = '' | split: '' %}
      {% if publication.keywords %}
        {% assign keyword_items = publication.keywords | split: ';' %}
      {% endif %}
      {% assign project_items = '' | split: '' %}
      {% if publication.projects %}
        {% assign project_items = publication.projects | split: ';' %}
      {% endif %}
      <li>
        <div class="row">
          <div class="col-sm-10">
            <div class="title">{{ publication.title }}</div>
            {% if publication.author %}
              {% assign author_items = publication.author | split: ' and ' %}
              {% assign author_limit = author_items.size %}
              {% if site.max_author_limit and author_items.size > site.max_author_limit %}
                {% assign author_limit = site.max_author_limit %}
              {% endif %}
              <div class="author">
                {%- for author in author_items limit: author_limit -%}
                  {%- assign clean_author = author | strip -%}
                  {%- if clean_author != '' -%}
                    {%- if forloop.length > 1 -%}
                      {%- if forloop.first == false -%}
                        {%- if forloop.length > 2 -%}, {% elsif forloop.length == 2 -%} {% endif -%}
                      {%- endif -%}
                      {%- if forloop.last and author_limit == author_items.size -%}and {% endif -%}
                    {%- endif -%}
                    {{ clean_author }}
                  {%- endif -%}
                {%- endfor -%}
                {%- assign more_authors = author_items.size | minus: author_limit -%}
                {%- if more_authors > 0 -%}
                  {%- assign more_authors_hide = more_authors | append: ' more author' -%}
                  {%- if more_authors > 1 -%}
                    {%- assign more_authors_hide = more_authors_hide | append: 's' -%}
                  {%- endif -%}
                  {%- assign more_authors_show = '' -%}
                  {%- for author in author_items offset: author_limit -%}
                    {%- assign more_authors_show = more_authors_show | append: author | strip -%}
                    {%- unless forloop.last -%}
                      {%- assign more_authors_show = more_authors_show | append: ', ' -%}
                    {%- endunless -%}
                  {%- endfor -%}
                  , and
                  <span
                    class="more-authors"
                    title="click to view {{ more_authors_hide }}"
                    onclick="
                        var element = $(this);
                        element.attr('title', '');
                        var more_authors_text = element.text() == '{{ more_authors_hide }}' ? '{{ more_authors_show }}' : '{{ more_authors_hide }}';
                        var cursorPosition = 0;
                        var textAdder = setInterval(function(){
                          element.html(more_authors_text.substring(0, cursorPosition + 1));
                          if (++cursorPosition == more_authors_text.length){
                            clearInterval(textAdder);
                          }
                      }, '{{ site.more_authors_animation_delay }}');
                    "
                  >
                    {{- more_authors_hide -}}
                  </span>
                {%- endif -%}
              </div>
            {% endif %}
            <div class="periodical">
              {% if publication.venue != blank -%}
                <em>{{ publication.venue }}</em>
              {%- endif -%}
              {%- if publication.venue != blank and publication.year != blank %}, {% endif -%}
              {%- if publication.year != blank %}{{ publication.year }}{% endif %}
            </div>
            {% if keyword_items.size > 0 %}
              <div class="publication-keyword-group publication-theme-group" aria-label="Publication themes">
                {% for keyword in keyword_items %}
                  {% assign clean_keyword = keyword | strip %}
                  {% if clean_keyword != '' %}
                    <span class="publication-keyword">{{ clean_keyword }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            {% if project_items.size > 0 %}
              <div class="publication-keyword-group publication-projects" aria-label="Related projects">
                {% for project in project_items %}
                  {% assign clean_project = project | strip %}
                  {% if clean_project != '' %}
                    {% assign project_label = clean_project %}
                    {% assign project_url = '' %}
                    {% for site_project in site.projects %}
                      {% assign site_project_key = site_project.project_filter | default: site_project.slug %}
                      {% if site_project_key == clean_project %}
                        {% assign project_label = site_project.title %}
                        {% assign project_url = site_project.url | relative_url %}
                        {% break %}
                      {% endif %}
                    {% endfor %}
                    {% if project_url != '' %}
                      <a class="publication-keyword publication-project" href="{{ project_url }}">{{ project_label }}</a>
                    {% else %}
                      <span class="publication-keyword publication-project">{{ project_label }}</span>
                    {% endif %}
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            <div class="links">
              {% if publication.doi_url != blank -%}
                <a href="{{ publication.doi_url }}" class="btn btn-sm z-depth-0 publication-cta publication-cta-read" role="button">READ THE PAPER</a>
              {%- endif %}
              {% if publication.code != blank -%}
                <a href="{{ publication.code }}" class="btn btn-sm z-depth-0 publication-cta publication-cta-code" role="button">Code</a>
              {%- endif %}
              {% if publication.pdf != blank -%}
                <a href="{{ publication.pdf }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
              {%- endif %}
              {% if publication.website != blank -%}
                <a href="{{ publication.website }}" class="btn btn-sm z-depth-0 publication-cta publication-cta-website" role="button">Website</a>
              {%- endif %}
            </div>
          </div>
        </div>
      </li>
    {% endfor %}
  </ol>
</div>
