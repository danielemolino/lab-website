<div class="lab-graph-toolbar">
  <div class="lab-graph-toolbar-row">
    <div class="lab-graph-mode-toggle" aria-label="Graph mode">
      <span class="lab-graph-chip is-active">Paper Graph</span>
    </div>

    <div class="lab-graph-toolbar-actions">
      <button type="button" class="lab-graph-button" data-graph-action="fit">Fit graph</button>
      <button type="button" class="lab-graph-button" data-graph-action="reset">Reset filters</button>
    </div>
  </div>

  <div class="lab-graph-toolbar-row lab-graph-toolbar-row-filters">
    <label class="lab-graph-field">
      <span>Search</span>
      <input id="lab-graph-search" type="search" placeholder="Search papers, venues, authors, topics">
    </label>

    <label class="lab-graph-field">
      <span>Links</span>
      <select id="lab-graph-link-filter">
        <option value="all">Authors + Keywords</option>
        <option value="authors">Authors only</option>
        <option value="keywords">Keywords only</option>
      </select>
    </label>

    <label class="lab-graph-field">
      <span>Topic</span>
      <select id="lab-graph-topic-filter">
        <option value="">All topics</option>
      </select>
    </label>

    <div class="lab-graph-field lab-graph-year-range">
      <span>Year range</span>
      <div class="lab-graph-year-range-values">
        <strong id="lab-graph-year-min-label">-</strong>
        <strong id="lab-graph-year-max-label">-</strong>
      </div>
      <input id="lab-graph-year-min" type="range" step="1">
      <input id="lab-graph-year-max" type="range" step="1">
    </div>
  </div>
</div>
